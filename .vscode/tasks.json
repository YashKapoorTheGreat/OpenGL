{
    "tasks": [
        {
            "type": "cppbuild",
            "label": "build project",
            "command": "C:\\MinGW\\bin\\g++.exe",
            "args": [
                "-DGLEW_STATIC",
                "-fdiagnostics-color=always",
                "${workspaceFolder}\\src\\*.cpp",
                "-g",
                "-I${workspaceFolder}\\include",
                "-L${workspaceFolder}\\lib",
                "-lglfw3",
                "-l:glew32s.lib",
                "-lopengl32",
                "-lgdi32",
                "-o",
                "${workspaceFolder}\\out\\build.exe"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "detail": "build"
        }
    ],
    "version": "2.0.0"
}